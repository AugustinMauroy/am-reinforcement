{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@am/reinforcement",
  "description": "A simple reinforcement learning implementation for JavaScript and TypeScript.",
  "version": "0.0.3",
  "license": "MIT",
  "exports": {
    "./algorithms": "./src/algorithms/mod.ts",
    "./memory": "./src/memory/mod.ts",
    "./policies": "./src/policies/mod.ts",
    "./utils": "./src/utils/mod.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "specifications.md",
      "src/**/*.ts",
      "jsr.json"
    ],
    "exclude": ["src/**/*.test.ts"]
  }
}
